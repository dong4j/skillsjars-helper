<!-- 插件配置文件。更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- 插件的唯一标识符。应该是完全限定名。在插件版本之间不能更改。 -->
    <id>dev.dong4j.idea.skillsjars.helper</id>

    <!-- 公共插件名称应使用标题大小写书写。
         指南：https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>SkillsJars Helper</name>

    <!-- 在插件页面上显示的供应商名称或组织ID。 -->
    <vendor email="dong4j@gmail.com">dong4j</vendor>

    <!-- 产品和插件兼容性要求。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <!-- Maven 集成可选依赖: 仅在 IDE 启用了 Maven 插件时才装载 skillsjars-maven.xml,
         其中包含 MavenPluginDependencyScanner 的注册. 缺失 Maven 插件时不影响其他扫描器. -->
    <depends optional="true" config-file="skillsjars-maven.xml">org.jetbrains.idea.maven</depends>

    <!-- 国际化资源文件 -->
    <resource-bundle>messages.SkillsJarsHelperBundle</resource-bundle>

    <!-- 插件自身定义的扩展点, 供本插件内部以及第三方插件扩展. -->
    <extensionPoints>
        <extensionPoint
            name="skillSourceScanner"
            interface="dev.dong4j.idea.skillsjars.helper.scanner.SkillSourceScanner"
            dynamic="true"/>
    </extensionPoints>

    <!-- 插件定义的扩展点。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- 通知组 -->
        <!--suppress PluginXmlI18n -->
        <notificationGroup id="SkillsJars Helper Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"/>

        <!-- 项目级 SkillRegistry 服务. 注册 serviceInterface 让外部插件以 API 类查找. -->
        <projectService
            serviceInterface="dev.dong4j.idea.skillsjars.helper.api.SkillRegistry"
            serviceImplementation="dev.dong4j.idea.skillsjars.helper.service.SkillRegistryService"/>

        <!-- 项目级 SkillExportService 服务: 暴露 skill 导出能力. -->
        <projectService
            serviceInterface="dev.dong4j.idea.skillsjars.helper.api.SkillExportService"
            serviceImplementation="dev.dong4j.idea.skillsjars.helper.service.SkillExportServiceImpl"/>

        <!-- 项目级 InstallationRegistry 服务: 维护 6 个预设 Agent 目录的安装状态索引. -->
        <projectService
            serviceImplementation="dev.dong4j.idea.skillsjars.helper.service.InstallationRegistryService"/>

        <!-- Agent Skills Tool Window. anchor=right 与依赖类工具更接近. -->
        <toolWindow
            id="Agent Skills"
            anchor="right"
            icon="icons.SkillsJarsHelperIcons.SKILLSJARS_HELPER_16"
            factoryClass="dev.dong4j.idea.skillsjars.helper.toolwindow.SkillsToolWindowFactory"/>
    </extensions>

    <!-- 注册到本插件自身扩展点的扫描器. Maven plugin <dependencies> 扫描器在 skillsjars-maven.xml. -->
    <extensions defaultExtensionNs="dev.dong4j.idea.skillsjars.helper">
        <skillSourceScanner
            implementation="dev.dong4j.idea.skillsjars.helper.scanner.MavenLibraryScanner"/>
    </extensions>

    <!-- 插件定义的动作 -->
    <actions>
        <!-- 编辑器右键菜单 -->
        <action id="dev.dong4j.idea.skillsjars.helper.action.SkillsJarsHelperAction"
                class="dev.dong4j.idea.skillsjars.helper.action.SkillsJarsHelperAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
