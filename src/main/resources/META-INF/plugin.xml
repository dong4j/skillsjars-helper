<!-- 插件配置文件。更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <!-- 插件的唯一标识符。应该是完全限定名。在插件版本之间不能更改。 -->
    <id>dev.dong4j.idea.skillsjars.helper</id>

    <!-- 公共插件名称应使用标题大小写书写。
         指南：https://plugins.jetbrains.com/docs/marketplace/plugin-overview-page.html#plugin-name -->
    <name>SkillsJars Helper</name>

    <!-- 在插件页面上显示的供应商名称或组织ID。 -->
    <vendor email="dong4j@gmail.com">dong4j</vendor>

    <!-- 产品和插件兼容性要求。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <!-- 国际化资源文件 -->
    <resource-bundle>messages.SkillsJarsHelperBundle</resource-bundle>

    <!-- 插件定义的扩展点。
         更多信息：https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- 通知组 -->
        <!--suppress PluginXmlI18n -->
        <notificationGroup id="SkillsJars Helper Notifications"
                           displayType="BALLOON"
                           isLogByDefault="true"/>
    </extensions>

    <!-- 插件定义的动作 -->
    <actions>
        <!-- 编辑器右键菜单 -->
        <action id="dev.dong4j.idea.skillsjars.helper.action.SkillsJarsHelperAction"
                class="dev.dong4j.idea.skillsjars.helper.action.SkillsJarsHelperAction">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>

